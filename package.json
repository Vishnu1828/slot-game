{
  "name": "slot-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently -k -n assets,vite -c blue,green \"npm:assets:watch\" \"vite --host 0.0.0.0\"",
    "assets": "assetpack",
    "assets:watch": "assetpack -w",
    "assets:prod": "rm -rf public/assets .assetpack && AP_CACHEBUST=1 assetpack",
    "build": "npm run lint && npm run assets:prod && vite build",
    "lint": "eslint ."
  },
  "dependencies": {
    "@pixi/layout": "^3.2.0",
    "@pixi/react": "^8.0.0",
    "@pixi/sound": "^6.0.1",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.17.0",
    "gsap": "^3.15.0",
    "pixi.js": "^8.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@assetpack/core": "^1.7.0",
    "@eslint/js": "^9.21.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^10.0.3",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.2.0"
  }
}
